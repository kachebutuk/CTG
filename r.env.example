# API Configuration
VITE_API_URL=http://localhost:8000/api
VITE_WS_URL=ws://localhost:8080/ws

# App Configuration
VITE_APP_NAME=CipherTrade
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=development

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_NOTIFICATIONS=true
VITE_ENABLE_DARK_MODE=true
VITE_ENABLE_ML_PREDICTIONS=false

# Authentication
VITE_AUTH_TOKEN_KEY=ciphertrade_auth_token
VITE_REFRESH_TOKEN_KEY=ciphertrade_refresh_token

# Trading Defaults
VITE_DEFAULT_SYMBOL=BTCUSDT
VITE_DEFAULT_TIMEFRAME=1h
VITE_MAX_LEVERAGE=100

# Chart Configuration
VITE_CHART_HEIGHT=400
VITE_CHART_SHOW_VOLUME=true

# WebSocket Reconnection
VITE_WS_RECONNECT_ATTEMPTS=5
VITE_WS_RECONNECT_INTERVAL=3000
VITE_WS_PING_INTERVAL=30000
VITE_WS_PONG_TIMEOUT=5000

# Pagination
VITE_DEFAULT_PAGE_SIZE=20
VITE_MAX_PAGE_SIZE=100

# Cache Duration (seconds)
VITE_CACHE_DURATION=300
VITE_MARKET_DATA_CACHE=60

# Rate Limiting
VITE_RATE_LIMIT_REQUESTS=100
VITE_RATE_LIMIT_WINDOW=60

# Analytics
VITE_ANALYTICS_ID=UA-XXXXXXXXX-X
VITE_SENTRY_DSN=

# Feature Toggles
VITE_FEATURE_BACKTESTING=true
VITE_FEATURE_OPTIMIZATION=true
VITE_FEATURE_PAPER_TRADING=true
VITE_FEATURE_SOCIAL_TRADING=false